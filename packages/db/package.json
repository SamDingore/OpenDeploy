{
  "name": "@opendeploy/db",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "generate": "prisma generate",
    "migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "push": "dotenv -e ../../.env -- prisma db push",
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src prisma --max-warnings 0"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@opendeploy/config": "workspace:*",
    "@types/node": "^22.10.2",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.17.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  }
}
