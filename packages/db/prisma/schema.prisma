generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum DeploymentStatus {
  created
  queued
  assigned
  fetching_source
  preparing_context
  building_image
  pushing_image
  build_succeeded
  build_failed
  cancelled
}

enum BuildFailureCode {
  github_webhook_invalid
  github_api_transient
  github_api_forbidden
  repo_fetch_failed
  repo_not_found
  dockerfile_invalid
  build_failed
  registry_push_failed
  timeout
  worker_internal_error
}

enum TriggerSource {
  manual
  push
  pull_request
}

enum DeploymentAttemptResult {
  succeeded
  failed
  cancelled
}

enum EnvironmentType {
  preview
  production
}

enum WorkerStatus {
  online
  offline
  draining
  error
  degraded
  quarantined
  retired
}

enum WebhookProvider {
  github
  clerk
}

enum ReleaseType {
  preview
  production
}

enum ReleaseStatus {
  pending
  provisioning_runtime
  starting
  health_checking
  active
  failed
  stopped
  rolled_back
  terminated
}

enum RuntimeInstanceStatus {
  created
  starting
  running
  unhealthy
  stopping
  stopped
  failed
}

enum RouteBindingStatus {
  pending
  attached
  detaching
  detached
  failed
}

enum PlatformHostnameKind {
  preview
  production
}

enum PlatformHostnameStatus {
  pending
  active
  retired
}

enum HealthCheckType {
  http
  tcp
}

enum CustomDomainStatus {
  pending
  awaiting_verification
  verified
  certificate_issuing
  certificate_active
  certificate_renewing
  active
  failed
  revoked
  detached
  deleted
}

enum DomainVerificationMethod {
  cname_and_txt
}

enum DomainFailureCode {
  invalid_hostname
  verification_not_found
  cname_misconfigured
  txt_misconfigured
  rate_limited
  acme_order_failed
  edge_attach_failed
  renewal_failed
}

enum DomainCheckMethod {
  dns_txt
  http_token
  cname_target
}

enum CertChallengeType {
  http_01
  dns_01
}

enum CertificateProvider {
  letsencrypt
}

enum CertificateRecordStatus {
  pending
  issuing
  active
  renewal_pending
  failed
  expired
}

enum NodePoolKind {
  build
  runtime
  edge
  mixed
}

enum NodeLeaseScopeType {
  build
  runtime
  edge_op
}

enum EgressPolicyTier {
  unrestricted
  allowlisted
  blocked
}

enum IsolationTier {
  standard
  hardened
  internal_trusted
}

enum RunnerClass {
  standard
  hardened
  internal_trusted
}

enum ReconciliationKind {
  runtime
  route
  domain
  node
  lease
  artifact
  edge_config
}

enum ReconciliationRunStatus {
  scheduled
  running
  completed
  partially_repaired
  failed
}

enum EdgeNodeStatus {
  active
  config_applying
  degraded
  offline
  quarantined
}

enum EdgeConfigApplyStatus {
  pending
  applied
  failed
  rolled_back
}

enum CapacityEventType {
  scale_out_requested
  scale_in_requested
  quota_denied
  queue_depth_high
  worker_pool_saturated
}

enum DomainEventType {
  domain_created
  verification_check
  verification_passed
  verification_failed
  certificate_order_started
  certificate_active
  certificate_renewal
  certificate_failure
  attach_requested
  attach_succeeded
  attach_failed
  detach
  reconcile
  status_transition
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships   WorkspaceMember[]
  auditEvents   AuditEvent[]      @relation("AuditActor")
  customDomains CustomDomain[]
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members              WorkspaceMember[]
  projects             Project[]
  installations        GitProviderInstallation[]
  deployments          Deployment[]
  releases             Release[]
  webhookEvents        WebhookEvent[]
  auditEvents          AuditEvent[]
  productionBranchRule String? // allowlisted branch for production triggers, Phase 1 optional field
  quota                WorkspaceQuota?
  runtimePolicies      RuntimePolicy[]
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Project {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  slug        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  repositoryLinks   RepositoryLink[]
  environments      Environment[]
  deployments       Deployment[]
  releases          Release[]
  platformHostnames PlatformHostname[]
  envSecrets        EnvironmentSecret[]
  customDomains     CustomDomain[]
  runtimePolicy     RuntimePolicy?

  @@unique([workspaceId, slug])
  @@index([workspaceId])
}

model GitProviderInstallation {
  id                     String   @id @default(cuid())
  workspaceId            String
  providerInstallationId String   @unique
  accountLogin           String?
  rawMetadata            Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  links     RepositoryLink[]
}

model RepositoryLink {
  id             String   @id @default(cuid())
  projectId      String
  installationId String
  providerRepoId String
  fullName       String
  defaultBranch  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project      Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  installation GitProviderInstallation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  @@unique([projectId])
  @@index([installationId])
}

model Environment {
  id          String          @id @default(cuid())
  projectId   String
  type        EnvironmentType
  name        String
  slug        String
  /// Container port your app listens on inside the image (Phase 3 runtime).
  runtimeContainerPort Int            @default(3000)
  /// JSON: { type: "http"|"tcp", path?: string, port?: number, startupTimeoutMs: number, steadyIntervalMs?: number }
  runtimeHealthCheck   Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  project             Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deployments         Deployment[]
  releases            Release[]
  platformHostnames   PlatformHostname[]
  activeReleaseId     String?              @unique
  activeRelease       Release?             @relation("EnvironmentActiveRelease", fields: [activeReleaseId], references: [id], onDelete: SetNull)
  envSecrets          EnvironmentSecret[]
  customDomains       CustomDomain[]

  @@unique([projectId, slug])
  @@index([projectId])
}

model Deployment {
  id            String            @id @default(cuid())
  workspaceId   String
  projectId     String
  environmentId String
  status        DeploymentStatus  @default(created)
  commitSha       String?
  branch          String?
  triggerSource   TriggerSource @default(manual)
  /// GitHub PR number when deployment is preview-from-PR (Phase 3).
  pullRequestNumber Int?
  buildStartedAt  DateTime?
  buildFinishedAt DateTime?
  buildDurationMs Int?
  failureCode     BuildFailureCode?
  failureDetail   String?
  gitRef          String? // optional ref hint (branch/tag) for manual triggers
  framework       String?
  installCommand  String?
  buildCommand    String?
  startCommand    String?
  rootDirectory   String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  attempts       DeploymentAttempt[]
  logs           DeploymentLogChunk[]
  artifacts      BuildArtifact[]
  sourceSnapshot SourceSnapshot?
  releases       Release[]

  @@index([workspaceId, projectId, environmentId])
  @@index([projectId, status])
  @@index([createdAt])
}

model DeploymentAttempt {
  id           String   @id @default(cuid())
  deploymentId String
  attemptNumber Int
  queueJobId   String?
  workerNodeId String?
  startedAt    DateTime?
  finishedAt   DateTime?
  result       DeploymentAttemptResult?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  deployment Deployment  @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  workerNode WorkerNode? @relation(fields: [workerNodeId], references: [id])

  @@unique([deploymentId, attemptNumber])
  @@index([deploymentId])
}

model DeploymentLogChunk {
  id           String   @id @default(cuid())
  deploymentId String
  seq          Int
  level        String
  message      String
  meta         Json?
  createdAt    DateTime @default(now())

  deployment Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  @@unique([deploymentId, seq])
  @@index([deploymentId, seq])
}

model BuildArtifact {
  id                 String   @id @default(cuid())
  deploymentId       String
  imageTag           String
  imageDigest        String?
  registryType       String?
  registryRepository String?
  buildContextBytes  Int?
  dockerfilePath     String?
  builderVersion     String?
  metadataJson       Json?
  createdAt          DateTime @default(now())

  deployment Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  releases   Release[]

  @@index([deploymentId, createdAt])
}

model Release {
  id                  String        @id @default(cuid())
  workspaceId         String
  projectId           String
  environmentId       String
  deploymentId        String
  buildArtifactId     String
  releaseType         ReleaseType
  status              ReleaseStatus @default(pending)
  pullRequestNumber   Int?
  commitSha           String
  activatedAt         DateTime?
  deactivatedAt       DateTime?
  rollbackOfReleaseId String?
  createdByUserId     String?
  failureDetail       String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment   Environment   @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  deployment    Deployment    @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  buildArtifact BuildArtifact @relation(fields: [buildArtifactId], references: [id], onDelete: Cascade)
  rollbackOf    Release?      @relation("ReleaseRollback", fields: [rollbackOfReleaseId], references: [id])
  rollbackChildren Release[]  @relation("ReleaseRollback")

  activeForEnvironment Environment? @relation("EnvironmentActiveRelease")

  runtimeInstances RuntimeInstance[]
  runtimeLogs      RuntimeLogChunk[]

  @@index([projectId, environmentId, status])
  @@index([pullRequestNumber, projectId, environmentId])
  @@index([deploymentId])
}

model RuntimeInstance {
  id                String                @id @default(cuid())
  releaseId         String
  workerNodeId      String?
  /// Docker container name we generate (safe DNS label on runtime network).
  containerName     String                @unique
  containerIdMasked String?
  imageTag          String
  imageDigest       String?
  status            RuntimeInstanceStatus @default(created)
  internalPort      Int
  /// Upstream dial host:port for the edge (usually containerName:internalPort).
  upstreamDial      String
  startedAt         DateTime?
  stoppedAt         DateTime?
  lastHealthStatus  String?
  metadataJson      Json?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  release         Release              @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  workerNode      WorkerNode?          @relation(fields: [workerNodeId], references: [id])
  healthResults   HealthCheckResult[]
  routeBindings   RouteBinding[]

  @@index([releaseId])
  @@index([workerNodeId])
}

model PlatformHostname {
  id                String                 @id @default(cuid())
  projectId         String
  environmentId     String
  hostname          String                 @unique
  kind              PlatformHostnameKind
  pullRequestNumber Int?
  status            PlatformHostnameStatus @default(active)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  routeBindings RouteBinding[]

  @@index([projectId, environmentId])
}

model RouteBinding {
  id                 String             @id @default(cuid())
  /// Null when this binding serves a verified custom domain only (Phase 4).
  platformHostnameId String?
  runtimeInstanceId  String
  status             RouteBindingStatus @default(pending)
  attachedAt         DateTime?
  detachedAt         DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  platformHostname PlatformHostname? @relation(fields: [platformHostnameId], references: [id], onDelete: Cascade)
  runtimeInstance  RuntimeInstance   @relation(fields: [runtimeInstanceId], references: [id], onDelete: Cascade)
  customDomain     CustomDomain?

  @@index([platformHostnameId, status])
  @@index([runtimeInstanceId])
}

model CustomDomain {
  id                    String                 @id @default(cuid())
  projectId             String
  environmentId       String
  hostname              String                 @unique
  apexDomain            String
  status                CustomDomainStatus     @default(pending)
  verificationMethod    DomainVerificationMethod @default(cname_and_txt)
  verificationToken     String
  verifiedAt            DateTime?
  lastCheckedAt         DateTime?
  activeCertificateId   String?                @unique
  routeBindingId        String?                @unique
  createdByUserId       String?
  failureCode           DomainFailureCode?
  failureDetail         String?
  lastIssuanceAttemptAt DateTime?
  nextRetryAt           DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  createdBy   User?       @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  activeCertificate CertificateRecord? @relation("CustomDomainActiveCert", fields: [activeCertificateId], references: [id], onDelete: SetNull)
  routeBinding      RouteBinding?      @relation(fields: [routeBindingId], references: [id], onDelete: SetNull)

  verificationChecks DomainVerificationCheck[]
  certificateHistory CertificateRecord[]       @relation("CustomDomainCerts")
  events             DomainEvent[]

  @@index([projectId, environmentId])
  @@index([status])
  @@index([nextRetryAt])
}

model DomainVerificationCheck {
  id             String           @id @default(cuid())
  customDomainId String
  method         DomainCheckMethod
  result         Boolean
  observedValue  String?
  checkedAt      DateTime         @default(now())
  errorDetail    String?

  customDomain CustomDomain @relation(fields: [customDomainId], references: [id], onDelete: Cascade)

  @@index([customDomainId, checkedAt])
}

model CertificateRecord {
  id                 String                  @id @default(cuid())
  customDomainId     String
  provider           CertificateProvider     @default(letsencrypt)
  status             CertificateRecordStatus @default(pending)
  challengeType      CertChallengeType       @default(http_01)
  externalOrderRef   String?
  notBefore          DateTime?
  notAfter           DateTime?
  renewalAttemptedAt DateTime?
  renewalSucceededAt DateTime?
  failureCode        DomainFailureCode?
  failureDetail      String?
  serialNumberMasked String?
  metadataJson       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customDomain       CustomDomain @relation("CustomDomainCerts", fields: [customDomainId], references: [id], onDelete: Cascade)
  activeForDomain    CustomDomain? @relation("CustomDomainActiveCert")

  @@index([customDomainId, createdAt])
  @@index([notAfter])
}

model DomainEvent {
  id             String          @id @default(cuid())
  customDomainId String
  type           DomainEventType
  payloadJson    Json?
  createdAt      DateTime        @default(now())

  customDomain CustomDomain @relation(fields: [customDomainId], references: [id], onDelete: Cascade)

  @@index([customDomainId, createdAt])
}

model HealthCheckResult {
  id                String          @id @default(cuid())
  runtimeInstanceId String
  checkType         HealthCheckType
  success           Boolean
  latencyMs         Int?
  detail            String?
  createdAt         DateTime        @default(now())

  runtimeInstance RuntimeInstance @relation(fields: [runtimeInstanceId], references: [id], onDelete: Cascade)

  @@index([runtimeInstanceId, createdAt])
}

model RuntimeLogChunk {
  id        String   @id @default(cuid())
  releaseId String
  seq       Int
  level     String
  message   String
  meta      Json?
  createdAt DateTime @default(now())

  release Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@unique([releaseId, seq])
  @@index([releaseId, seq])
}

model EnvironmentSecret {
  id            String   @id @default(cuid())
  projectId     String
  environmentId String
  name          String
  /// AES-256-GCM payload (base64) — ciphertext only; never log plaintext.
  valueEncrypted String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  @@unique([environmentId, name])
  @@index([projectId])
}

model SourceSnapshot {
  id             String   @id @default(cuid())
  deploymentId   String   @unique
  repoOwner      String?
  repoName       String?
  installationId String?
  commitSha      String
  cloneUrlMasked String?
  defaultBranch  String?
  createdAt      DateTime @default(now())

  deployment Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
}

model NodePool {
  id                   String       @id @default(cuid())
  name                 String       @unique
  kind                 NodePoolKind @default(mixed)
  isHardened           Boolean      @default(false)
  supportsRootless     Boolean      @default(false)
  capacityCpu          Int?
  capacityMemoryMb     Int?
  maxConcurrentBuilds  Int          @default(4)
  maxConcurrentRuntimes Int         @default(20)
  labelsJson           Json?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  workerNodes    WorkerNode[]
  capacityEvents CapacityEvent[]
}

model WorkerNode {
  id         String       @id @default(cuid())
  name       String
  status     WorkerStatus @default(offline)
  lastHeartbeatAt DateTime?
  supportsBuildkit Boolean @default(true)
  supportsRegistryPush Boolean @default(false)
  rootlessCapable Boolean @default(false)
  runnerClass    RunnerClass @default(standard)
  /// Opaque fingerprint from worker at register time (e.g. machine id hash); not a secret.
  workerIdentityFingerprint String?
  nodePoolId String?
  availableCpu Int?
  availableMemoryMb Int?
  metadata   Json?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  nodePool         NodePool?         @relation(fields: [nodePoolId], references: [id], onDelete: SetNull)
  attempts          DeploymentAttempt[]
  runtimeInstances  RuntimeInstance[]
  leases            NodeLease[]

  @@index([nodePoolId])
  @@index([status])
}

model NodeLease {
  id           String             @id @default(cuid())
  workerNodeId String
  scopeType    NodeLeaseScopeType
  scopeId      String
  acquiredAt   DateTime           @default(now())
  expiresAt    DateTime
  releasedAt   DateTime?

  workerNode WorkerNode @relation(fields: [workerNodeId], references: [id], onDelete: Cascade)

  @@index([workerNodeId, scopeType, releasedAt])
  @@index([expiresAt])
}

model RuntimePolicy {
  id             String           @id @default(cuid())
  workspaceId    String?
  projectId      String?          @unique
  cpuLimit       Int?
  memoryLimitMb  Int?
  maxReplicas    Int              @default(1)
  egressPolicy   EgressPolicyTier @default(unrestricted)
  isolationTier  IsolationTier    @default(standard)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model WorkspaceQuota {
  workspaceId            String @id
  maxConcurrentBuilds    Int    @default(5)
  maxConcurrentRuntimes  Int    @default(20)
  maxCertJobsInFlight    Int    @default(10)
  maxEdgeReloadsPerHour  Int    @default(120)
  maxCustomDomains       Int    @default(50)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model CapacityEvent {
  id         String            @id @default(cuid())
  nodePoolId String?
  type       CapacityEventType
  payloadJson Json?
  createdAt  DateTime          @default(now())

  nodePool NodePool? @relation(fields: [nodePoolId], references: [id], onDelete: SetNull)

  @@index([nodePoolId, createdAt])
  @@index([createdAt])
}

model ReconciliationRun {
  id             String                  @id @default(cuid())
  kind           ReconciliationKind
  startedAt      DateTime                @default(now())
  finishedAt     DateTime?
  status         ReconciliationRunStatus @default(running)
  itemsExamined  Int                     @default(0)
  itemsRepaired  Int                     @default(0)
  errorSummary   String?
  metadataJson   Json?

  @@index([kind, startedAt])
}

model TelemetrySpanLink {
  id           String   @id @default(cuid())
  resourceType String
  resourceId   String
  traceId      String
  spanId       String?
  recordedAt   DateTime @default(now())

  @@index([resourceType, resourceId])
  @@index([traceId])
}

model EdgeNode {
  id                   String          @id @default(cuid())
  name                 String          @unique
  status               EdgeNodeStatus  @default(active)
  caddyAdminSocketPath String?
  publicBaseUrl        String?
  lastHeartbeatAt      DateTime?
  metadataJson         Json?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  configVersions EdgeConfigVersion[]
}

model EdgeConfigVersion {
  id          String                @id @default(cuid())
  edgeNodeId  String?
  version     Int
  configHash  String
  bodySnapshot String               @db.Text
  applyStatus EdgeConfigApplyStatus @default(applied)
  appliedAt   DateTime              @default(now())
  errorDetail String?
  actorHint   String?

  edgeNode EdgeNode? @relation(fields: [edgeNodeId], references: [id], onDelete: SetNull)

  @@unique([edgeNodeId, version])
  @@index([edgeNodeId, appliedAt])
}

model WebhookEvent {
  id             String          @id @default(cuid())
  workspaceId    String?
  provider       WebhookProvider
  deliveryId     String
  eventType      String
  idempotencyKey String          @unique
  payload        Json
  processed      Boolean         @default(false)
  processedAt    DateTime?
  error          String?
  createdAt      DateTime        @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@unique([provider, deliveryId])
  @@index([provider, processed])
  @@index([workspaceId])
}

model AuditEvent {
  id          String   @id @default(cuid())
  workspaceId String?
  actorUserId String?
  action      String
  resource    String
  resourceId  String?
  metadata    Json?
  createdAt   DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  actor     User?      @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([actorUserId])
}
