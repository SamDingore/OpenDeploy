// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?
}

/// GitHub OAuth connection for a Clerk user (used for repo/org API and deployments).
model GithubConnection {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  githubId    Int
  githubLogin String
  accessToken String   @db.Text
  scope       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GithubRepository {
  id            String    @id @default(cuid())
  githubRepoId  BigInt    @unique
  ownerLogin    String
  name          String
  fullName      String
  defaultBranch String?
  isPrivate     Boolean
  htmlUrl       String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  projects      Project[]
}

model Project {
  id                 String           @id @default(cuid())
  clerkUserId        String
  name               String
  framework          String           @default("Unknown")
  productionDomain   String?
  githubRepositoryId String
  githubRepository   GithubRepository @relation(fields: [githubRepositoryId], references: [id], onDelete: Restrict)
  deployments        Deployment[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@unique([clerkUserId, githubRepositoryId])
  @@index([clerkUserId, createdAt(sort: Desc)])
}

/// A deployment record (build/run metadata). Actual deploy execution is not implemented yet.
enum DeploymentStatus {
  READY
  ERROR
  BUILDING
  QUEUED
  INITIALIZING
  CANCELLED
}

model Deployment {
  id              String            @id @default(cuid())
  projectId       String
  project         Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status          DeploymentStatus  @default(QUEUED)
  sourceBranch    String?
  commitSha       String?
  commitMessage   String?
  deployedBy      String?
  buildDurationMs Int?
  /// Persisted deployment pipeline log lines (JSON array) for replay after restart.
  streamLogs      Json              @default("[]")
  /// Persisted pipeline stage progress (JSON array) for replay after restart.
  streamStages    Json              @default("[]")
  config          DeploymentConfig?
  environmentVars DeploymentEnvVar[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([projectId, createdAt(sort: Desc)])
}

/// User-provided deployment setup configuration.
model DeploymentConfig {
  id              String     @id @default(cuid())
  deploymentId    String     @unique
  deployment      Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  projectName     String
  frameworkPreset String
  rootDirectory   String     @default("./")
  buildCommand    String?
  outputDirectory String?
  installCommand  String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

/// Environment variables scoped to one deployment setup.
model DeploymentEnvVar {
  id           String     @id @default(cuid())
  deploymentId String
  deployment   Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  key          String
  value        String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([deploymentId])
}
