// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?
}

/// GitHub OAuth connection for a Clerk user (used for repo/org API and deployments).
model GithubConnection {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  githubId    Int
  githubLogin String
  accessToken String   @db.Text
  scope       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GithubRepository {
  id            String    @id @default(cuid())
  githubRepoId  BigInt    @unique
  ownerLogin    String
  name          String
  fullName      String
  defaultBranch String?
  isPrivate     Boolean
  htmlUrl       String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  projects      Project[]
}

model Project {
  id                 String           @id @default(cuid())
  clerkUserId        String
  name               String
  framework          String           @default("Unknown")
  productionDomain   String?
  githubRepositoryId String
  githubRepository   GithubRepository @relation(fields: [githubRepositoryId], references: [id], onDelete: Restrict)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@unique([clerkUserId, githubRepositoryId])
  @@index([clerkUserId, createdAt(sort: Desc)])
}
