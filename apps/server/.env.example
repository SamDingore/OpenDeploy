# HTTP port for the Nest API (use a port different from the Next.js app)
PORT=4000

# PostgreSQL connection string used by Prisma (`prisma.config.ts`) and the pg adapter
# Replace user, password, host, port, and database name as needed.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/opendeploy?schema=public"

# Redis for BullMQ (deployment queue). Start Redis with: pnpm docker:up (see docker/docker-compose.yml)
# REDIS_URL=redis://localhost:6379

# Clerk (required for GitHub connect and other authenticated API routes)
# CLERK_SECRET_KEY=
# CLERK_JWT_KEY=
# CLERK_AUTHORIZED_PARTIES=

# Next.js app origin (CORS + post-OAuth redirect base if WEB_APP_URL is unset)
# WEB_APP_URL=http://localhost:3000
# Optional: extra allowed browser origins (comma-separated), e.g. http://127.0.0.1:3000
# WEB_APP_URLS=http://127.0.0.1:3000

# GitHub OAuth App (https://github.com/settings/developers)
# Authorization callback URL must match GITHUB_OAUTH_CALLBACK_URL exactly
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# GITHUB_OAUTH_CALLBACK_URL=http://localhost:4000/apis/github/oauth/callback
# Random secret for signing OAuth state (e.g. openssl rand -hex 32)
# GITHUB_OAUTH_STATE_SECRET=
