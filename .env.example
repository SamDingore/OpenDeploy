# Database (Docker Compose default)
DATABASE_URL=postgresql://opendeploy:opendeploy@localhost:5432/opendeploy

# Redis
REDIS_URL=redis://127.0.0.1:6379

# API
PORT=3001
NODE_ENV=development
APP_ORIGIN=http://localhost:3000
API_PUBLIC_URL=http://localhost:3001
INTERNAL_API_SECRET=change-me-please-16chars-min

# Clerk (https://dashboard.clerk.com)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# Web (Next.js) — copy to apps/web/.env.local
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_API_URL=http://localhost:3001
API_URL=http://localhost:3001

# GitHub App (optional in Phase 1)
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Clerk webhooks (optional)
CLERK_WEBHOOK_SECRET=

# Phase 3–5 — platform routing + custom domains (Caddy) + edge versioning
PLATFORM_PUBLIC_DOMAIN=deploy.local
# Local: http://localhost:2019 when Caddy from docker-compose exposes admin
# CADDY_ADMIN_URL=http://localhost:2019
# Production-style: admin API over Unix socket (preferred when untrusted code shares the host)
# CADDY_ADMIN_UNIX_SOCKET=/var/run/caddy-admin.sock
# Optional logical name for EdgeNode + EdgeConfigVersion scoping
# EDGE_NODE_NAME=edge-1
# Optional ACME email for public TLS on real domains
# CADDY_ACME_EMAIL=you@example.com
# Optional: write generated Caddyfile for volume-based reloads
# CADDYFILE_PATH=./infra/docker/caddy/generated.Caddyfile
# Preview GC fallback (hours)
# PREVIEW_TTL_HOURS=168
# 64 hex chars (32 bytes) for AES-256-GCM environment secrets
# SECRETS_ENCRYPTION_KEY=

# Worker runtime containers (host Docker CLI)
# RUNTIME_DOCKER_NETWORK=opendeploy_runtime
# RUNTIME_MEMORY_LIMIT=512m
# RUNTIME_CPU_LIMIT=1

# Worker — Phase 5 pool / identity hints (optional)
# WORKER_NODE_POOL=default
# WORKER_ROOTLESS_CAPABLE=true
# WORKER_IDENTITY_FINGERPRINT=sha256:...

# Phase 5 — OpenTelemetry (traces via OTLP HTTP)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_SERVICE_NAME=opendeploy-local
# OTEL_SDK_DISABLED=true

# API reconciler cron (set false to disable 5-minute reconciliation loop)
# ENABLE_RECONCILER=true

# Optional observability
# SENTRY_DSN=

# Seed (optional)
# SEED_CLERK_USER_ID=user_xxx
