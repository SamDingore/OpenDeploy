# Database (Docker Compose default)
DATABASE_URL=postgresql://opendeploy:opendeploy@localhost:5432/opendeploy

# Redis
REDIS_URL=redis://127.0.0.1:6379

# API
PORT=3001
NODE_ENV=development
APP_ORIGIN=http://localhost:3000
API_PUBLIC_URL=http://localhost:3001
INTERNAL_API_SECRET=change-me-please-16chars-min

# Clerk (https://dashboard.clerk.com)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# Web (Next.js) — copy to apps/web/.env.local
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_API_URL=http://localhost:3001
API_URL=http://localhost:3001

# GitHub App (optional in Phase 1)
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Clerk webhooks (optional)
CLERK_WEBHOOK_SECRET=

# Optional observability
# SENTRY_DSN=

# Seed (optional)
# SEED_CLERK_USER_ID=user_xxx
