{
  "name": "opendeploy",
  "private": true,
  "packageManager": "pnpm@10.19.0+sha512.c9fc7236e92adf5c8af42fd5bf1612df99c2ceb62f27047032f4720b33f8eacdde311865e91c411f2774f618d82f320808ecb51718bfa82c060c4ba7c76a32b8",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:server": "pnpm --filter server start:dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "db:generate": "pnpm --filter server run db:generate",
    "db:migrate": "pnpm --filter server run db:migrate",
    "db:push": "pnpm --filter server run db:push",
    "db:studio": "pnpm --filter server run db:studio",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:logs": "docker compose -f docker/docker-compose.yml logs -f"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@nestjs/core"],
    "ignoredBuiltDependencies": ["sharp", "unrs-resolver"]
  }
}
