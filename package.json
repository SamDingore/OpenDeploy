{
  "name": "opendeploy",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "postinstall": "pnpm db:generate",
    "build": "pnpm -r run build",
    "dev": "pnpm run --parallel --filter @opendeploy/api --filter @opendeploy/web dev",
    "dev:api": "pnpm --filter @opendeploy/api dev",
    "dev:web": "pnpm --filter @opendeploy/web dev",
    "dev:worker": "pnpm --filter @opendeploy/worker dev",
    "lint": "pnpm -r run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "test": "pnpm -r run test",
    "db:generate": "pnpm --filter @opendeploy/db generate",
    "db:migrate": "pnpm --filter @opendeploy/db migrate",
    "db:push": "pnpm --filter @opendeploy/db push",
    "db:seed": "pnpm --filter @opendeploy/db seed",
    "typecheck": "pnpm -r run typecheck"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
